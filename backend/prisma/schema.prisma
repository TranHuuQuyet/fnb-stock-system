generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  MUST_CHANGE_PASSWORD
}

enum NetworkWhitelistType {
  IP
  SSID
}

enum BatchStatus {
  ACTIVE
  SOFT_LOCKED
  DEPLETED
  EXPIRED
}

enum StockAdjustmentType {
  INCREASE
  DECREASE
}

enum ScanSource {
  ONLINE
  OFFLINE_SYNC
  MANUAL_ENTRY
}

enum ScanResultStatus {
  SUCCESS
  WARNING
  ERROR
}

enum ScanEntryMethod {
  CAMERA
  MANUAL
}

enum ScanOperationType {
  STORE_USAGE
  TRANSFER
}

enum StockTransferStatus {
  IN_TRANSIT
  RECEIVED
}

enum FraudAttemptType {
  NETWORK_RESTRICTED
  INVALID_QR
  UNKNOWN_BATCH
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum WorkScheduleStatus {
  DRAFT
  PUBLISHED
  LOCKED
}

enum WorkEntryType {
  TRIAL
  OFFICIAL
}

model User {
  id            String       @id @default(cuid())
  username      String       @unique
  fullName      String
  passwordHash  String
  role          UserRole
  storeId       String?
  status        UserStatus   @default(MUST_CHANGE_PASSWORD)
  permissions   String[]     @default([])
  failedLoginAttempts Int    @default(0)
  lastFailedLoginAt DateTime?
  lockoutUntil  DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  store         Store?       @relation(fields: [storeId], references: [id])
  devices       Device[]
  scanLogs      ScanLog[]
  fraudAttempts FraudAttemptLog[]
  adjustments   StockAdjustment[]
  audits        AuditLog[]
  workScheduleEmployees WorkScheduleEmployee[]
  createdTransfers StockTransfer[] @relation("CreatedStockTransfers")
  confirmedTransfers StockTransfer[] @relation("ConfirmedStockTransfers")

  @@index([storeId])
  @@index([createdAt])
  @@index([lockoutUntil])
}

model Store {
  id                String                  @id @default(cuid())
  code              String                  @unique
  name              String
  timezone          String                  @default("Asia/Ho_Chi_Minh")
  isActive          Boolean                 @default(true)
  networkBypassEnabled   Boolean            @default(false)
  networkBypassExpiresAt DateTime?
  networkBypassReason    String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  users             User[]
  networkWhitelists StoreNetworkWhitelist[]
  devices           Device[]
  batches           IngredientBatch[]
  adjustments       StockAdjustment[]
  scanLogs          ScanLog[]               @relation("ScanStore")
  transferScanLogs  ScanLog[]               @relation("TransferDestinationStore")
  fraudAttempts     FraudAttemptLog[]
  posSales          PosSale[]
  anomalyAlerts     AnomalyAlert[]
  workSchedules     WorkSchedule[]
  ingredientStockLayouts IngredientStockLayout[]
  outgoingTransfers StockTransfer[] @relation("SourceStockTransfers")
  incomingTransfers StockTransfer[] @relation("DestinationStockTransfers")

  @@index([createdAt])
  @@index([networkBypassEnabled, networkBypassExpiresAt])
}

model StoreNetworkWhitelist {
  id        String               @id @default(cuid())
  storeId   String
  type      NetworkWhitelistType
  value     String
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  store     Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, type, value])
  @@index([storeId, type])
}

model Device {
  id          String   @id @default(cuid())
  deviceId    String   @unique
  userId      String?
  storeId     String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([userId])
}

model Ingredient {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  unit      String
  groupId   String
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  group     IngredientGroup   @relation(fields: [groupId], references: [id], onDelete: Restrict)
  batches   IngredientBatch[]
  recipes   Recipe[]
  alerts    AnomalyAlert[]
  stockLayoutItems IngredientStockLayoutItem[]
  stockTransfers StockTransfer[]

  @@index([createdAt])
  @@index([groupId])
}

model IngredientUnit {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
}

model IngredientGroup {
  id          String                     @id @default(cuid())
  name        String
  normalizedName String                 @unique
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  ingredients Ingredient[]
  stockLayoutGroups IngredientStockLayoutGroup[]

  @@index([createdAt])
}

model IngredientBatch {
  id             String           @id @default(cuid())
  ingredientId   String
  storeId        String
  batchCode      String
  receivedAt     DateTime
  expiredAt      DateTime?
  initialQty     Float
  remainingQty   Float
  status         BatchStatus      @default(ACTIVE)
  softLockReason String?
  qrCodeValue    String?
  qrGeneratedAt  DateTime?
  labelCreatedAt DateTime?
  printedLabelCount Int           @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  ingredient     Ingredient       @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  store          Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  adjustments    StockAdjustment[]
  scanLogs       ScanLog[]
  outgoingTransfers StockTransfer[] @relation("SourceBatchTransfers")
  incomingTransfers StockTransfer[] @relation("DestinationBatchTransfers")

  @@unique([storeId, batchCode])
  @@index([storeId, status, receivedAt])
  @@index([ingredientId, storeId, receivedAt])
  @@index([createdAt])
}

model StockAdjustment {
  id              String              @id @default(cuid())
  storeId         String
  batchId         String
  adjustmentType  StockAdjustmentType
  quantity        Float
  reason          String
  createdByUserId String
  createdAt       DateTime            @default(now())
  store           Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  batch           IngredientBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdByUser   User                @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([storeId, createdAt])
  @@index([batchId, createdAt])
}

model ScanLog {
  id            String           @id @default(cuid())
  clientEventId String           @unique
  storeId       String
  destinationStoreId String?
  userId        String
  deviceId      String
  batchId       String?
  quantityUsed  Float
  scannedAt     DateTime
  receivedAt    DateTime
  source        ScanSource
  entryMethod   ScanEntryMethod  @default(CAMERA)
  operationType ScanOperationType @default(STORE_USAGE)
  ipAddress     String
  ssid          String?
  resultStatus  ScanResultStatus
  resultCode    String
  message       String
  duplicated    Boolean          @default(false)
  createdAt     DateTime         @default(now())
  store         Store            @relation("ScanStore", fields: [storeId], references: [id], onDelete: Cascade)
  destinationStore Store?        @relation("TransferDestinationStore", fields: [destinationStoreId], references: [id], onDelete: SetNull)
  user          User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  batch         IngredientBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([destinationStoreId, createdAt])
  @@index([userId, createdAt])
  @@index([batchId])
  @@index([scannedAt])
  @@index([operationType, createdAt])
}

model FraudAttemptLog {
  id          String           @id @default(cuid())
  storeId     String
  userId      String?
  deviceId    String?
  ipAddress   String
  ssid        String?
  attemptType FraudAttemptType
  detail      String
  createdAt   DateTime         @default(now())
  store       Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([userId, createdAt])
}

model PosProduct {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  recipes   Recipe[]
  sales     PosSale[]

  @@index([createdAt])
}

model Recipe {
  id           String     @id @default(cuid())
  productId    String
  ingredientId String
  qtyPerUnit   Float
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  product      PosProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@index([productId])
  @@index([ingredientId])
}

model PosSale {
  id           String     @id @default(cuid())
  storeId      String
  productId    String
  businessDate DateTime
  qtySold      Float
  createdAt    DateTime   @default(now())
  store        Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product      PosProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId, businessDate])
  @@index([storeId, businessDate])
}

model AnomalyAlert {
  id           String        @id @default(cuid())
  storeId      String
  businessDate DateTime
  ingredientId String
  expectedQty  Float
  actualQty    Float
  ratio        Float
  severity     AlertSeverity
  message      String
  status       AlertStatus   @default(OPEN)
  createdAt    DateTime      @default(now())
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient    @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([storeId, businessDate, ingredientId])
  @@index([storeId, businessDate])
}

model AppConfig {
  id               String   @id @default("default")
  allowFifoBypass  Boolean  @default(true)
  anomalyThreshold Float    @default(0.7)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String
  oldData     Json?
  newData     Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}

model StockTransfer {
  id                String              @id @default(cuid())
  sourceStoreId     String
  destinationStoreId String
  sourceBatchId     String
  destinationBatchId String?
  ingredientId      String
  batchCode         String
  quantityRequested Float
  quantityReceived  Float?
  status            StockTransferStatus @default(IN_TRANSIT)
  requestedAt       DateTime
  confirmedAt       DateTime?
  confirmationNote  String?
  createdByUserId   String
  confirmedByUserId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  sourceStore       Store               @relation("SourceStockTransfers", fields: [sourceStoreId], references: [id], onDelete: Restrict)
  destinationStore  Store               @relation("DestinationStockTransfers", fields: [destinationStoreId], references: [id], onDelete: Restrict)
  sourceBatch       IngredientBatch     @relation("SourceBatchTransfers", fields: [sourceBatchId], references: [id], onDelete: Restrict)
  destinationBatch  IngredientBatch?    @relation("DestinationBatchTransfers", fields: [destinationBatchId], references: [id], onDelete: SetNull)
  ingredient        Ingredient          @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  createdByUser     User                @relation("CreatedStockTransfers", fields: [createdByUserId], references: [id], onDelete: Restrict)
  confirmedByUser   User?               @relation("ConfirmedStockTransfers", fields: [confirmedByUserId], references: [id], onDelete: SetNull)

  @@index([sourceStoreId, requestedAt])
  @@index([destinationStoreId, status, requestedAt])
  @@index([status, requestedAt])
  @@index([batchCode, requestedAt])
}

model IngredientStockLayout {
  id            String                     @id @default(cuid())
  storeId       String
  operationType ScanOperationType         @default(STORE_USAGE)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  store         Store                     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  groups        IngredientStockLayoutGroup[]

  @@unique([storeId, operationType])
  @@index([storeId, operationType])
}

model IngredientStockLayoutGroup {
  id        String                     @id @default(cuid())
  layoutId  String
  groupId   String
  sortOrder Int                        @default(0)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  layout    IngredientStockLayout      @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  group     IngredientGroup            @relation(fields: [groupId], references: [id], onDelete: Restrict)
  items     IngredientStockLayoutItem[]

  @@unique([layoutId, groupId])
  @@index([layoutId, sortOrder])
  @@index([groupId])
}

model IngredientStockLayoutItem {
  id            String                    @id @default(cuid())
  layoutGroupId String
  ingredientId  String
  sortOrder     Int                       @default(0)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  layoutGroup   IngredientStockLayoutGroup @relation(fields: [layoutGroupId], references: [id], onDelete: Cascade)
  ingredient    Ingredient                @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@unique([layoutGroupId, ingredientId])
  @@index([layoutGroupId, sortOrder])
  @@index([ingredientId])
}

model WorkSchedule {
  id        String             @id @default(cuid())
  storeId   String
  year      Int
  month     Int
  title     String
  notes     String?
  status    WorkScheduleStatus @default(DRAFT)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  store     Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shifts    WorkScheduleShift[]
  employees WorkScheduleEmployee[]

  @@unique([storeId, year, month])
}

model WorkScheduleShift {
  id             String            @id @default(cuid())
  workScheduleId String
  key            String
  code           String
  name           String
  startTime      String
  endTime        String
  durationHours  Float
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  workSchedule   WorkSchedule      @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)
  entries        WorkScheduleEntry[]

  @@unique([workScheduleId, key])
  @@index([workScheduleId, sortOrder])
}

model WorkScheduleEmployee {
  id                String              @id @default(cuid())
  workScheduleId    String
  userId            String
  displayName       String
  sortOrder         Int                 @default(0)
  trialHourlyRate   Float               @default(0)
  officialHourlyRate Float              @default(0)
  allowanceAmount   Float               @default(0)
  lateMinutes       Int                 @default(0)
  earlyLeaveMinutes Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workSchedule      WorkSchedule        @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  entries           WorkScheduleEntry[]

  @@unique([workScheduleId, userId])
  @@index([workScheduleId, sortOrder])
  @@index([userId])
}

model WorkScheduleEntry {
  id                     String               @id @default(cuid())
  workScheduleEmployeeId String
  shiftId                String
  day                    Int
  entryType              WorkEntryType
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  workScheduleEmployee   WorkScheduleEmployee @relation(fields: [workScheduleEmployeeId], references: [id], onDelete: Cascade)
  shift                  WorkScheduleShift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([workScheduleEmployeeId, shiftId, day])
  @@index([shiftId, day])
  @@index([workScheduleEmployeeId, day])
}
